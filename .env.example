# Preach the Word — environment variables
# Copy to .env.local for local dev, and add the same keys in the Vercel dashboard.
# .env.local is gitignored; never commit real secrets.

# Note: the canonical site URL and the GitHub repo coordinates (owner/name/branch/
# content path) are hardcoded in the app (lib/site.ts, lib/admin/config.ts) — they
# never change per environment, so they are NOT env vars.

# ---------------------------------------------------------------------------
# GitHub — content writes (REQUIRED for the admin panel)
# Each admin save commits data/content.json, which auto-triggers a Vercel rebuild.
# Create a *fine-grained* Personal Access Token scoped to ONLY this repo with:
#   • Contents: Read and write   (required — commits content.json)
#   • Deployments: Read          (optional — powers the live "Releasing…" status;
#                                 without it the admin falls back to a ~3-min timer)
# (A GitHub App token works too.)
# ---------------------------------------------------------------------------
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Clerk — admin authentication (REQUIRED for the admin panel)
# Get the keys from the Clerk dashboard → API keys. In the dashboard:
#   • enable Email verification code (or magic link),
#   • DISABLE public sign-up,
#   • invite the 1–2 operator emails.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/sign-in
# No public sign-up — point sign-up at the sign-in screen.
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/admin/sign-in
# Where to land after a successful sign-in.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/admin

# Defense-in-depth allowlist (comma-separated). If set, only these emails may use
# the admin even if they somehow have a Clerk session. Leave empty to rely solely
# on the Clerk dashboard restriction.
ADMIN_ALLOWED_EMAILS=

# ---------------------------------------------------------------------------
# Slack — optional post-save notification (incoming webhook URL)
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# YouTube Data API — optional. Without it, title/thumbnail still auto-fill via
# keyless oEmbed, but `date` stays a manual picker. With a key, the publish date
# and description prefill too (spec §4 / D2).
# ---------------------------------------------------------------------------
YOUTUBE_API_KEY=
